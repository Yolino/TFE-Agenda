APP_NAME=TFE-Agenda
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de données locale de l'application
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=TFE-Agenda
DB_USERNAME=root
DB_PASSWORD=

# Base de données globale "bti" (utilisateurs, agences, départements...)
DB_BTI_HOST=127.0.0.1
DB_BTI_PORT=3306
DB_BTI_DATABASE=Bti
DB_BTI_USERNAME=root
DB_BTI_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

EMAIL_CRONS_ENABLED=false
